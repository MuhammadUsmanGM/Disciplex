# ===========================================
# Disciplex Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================

# Supabase Configuration
# Get these from your Supabase project settings > API
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Generative AI (for AI Reckoning)
# Get from https://makersuite.google.com/app/apikey
EXPO_PUBLIC_GOOGLE_AI_API_KEY=your_google_ai_api_key

# RevenueCat Configuration (for subscriptions)
# Get from https://app.revenuecat.com/
EXPO_PUBLIC_REVENUECAT_API_KEY=your_revenuecat_api_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your_revenuecat_android_key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_ios_key

# App Configuration
EXPO_PUBLIC_APP_ENV=development
# Options: development, staging, production

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true

# Push Notifications (Expo)
EXPO_PUBLIC_EXPO_PROJECT_ID=your_expo_project_id

# Deep Linking
EXPO_PUBLIC_SCHEME=disciplex

# Analytics (Optional - add your preferred analytics service)
# EXPO_PUBLIC_ANALYTICS_ID=your_analytics_tracking_id
